---
---

<section class="eva" id="eva">
  <!-- Initiales EH en fond, avec parallaxe -->
  <div class="eva__bg-initials" aria-hidden="true">
    <span>EH</span>
  </div>

  <div class="container eva__inner">
    <div class="eva__meta" data-reveal>
      <span class="eyebrow">Eva Hayoun</span>
      <p class="eva__barreau">Avocate au Barreau de La Roche-sur-Yon</p>
    </div>

    <div class="eva__content">
      <h2 class="eva__titre" data-reveal>
        Une défense<br /><em>sur mesure.</em>
      </h2>

      <div class="eva__corps" data-reveal-stagger>
        <p>
          Je suis avocate à La Roche-sur-Yon. J'interviens aussi à Nantes,
          en Ille-et-Vilaine et aux alentours d'Orléans.
        </p>
        <p>
          Ce qui m'importe : comprendre votre situation avant toute chose,
          et vous défendre avec clarté — sans jargon, sans distance.
        </p>
      </div>

      <div class="eva__line" data-reveal aria-hidden="true"></div>

      <ul class="eva__tags" data-reveal-stagger>
        <li>Écoute</li>
        <li>Clarté</li>
        <li>Engagement</li>
      </ul>
    </div>
  </div>
</section>

<style>
.eva {
  position: relative;
  background: var(--cream);
  padding: 8rem 0;
  overflow: hidden;
}

.eva__bg-initials {
  position: absolute;
  right: -2rem;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
  user-select: none;
  will-change: transform;
}
.eva__bg-initials span {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: clamp(14rem, 22vw, 22rem);
  font-weight: 500;
  color: rgba(26,26,24,0.04);
  line-height: 1;
}

.eva__inner {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 5rem;
  align-items: start;
  position: relative;
  z-index: 1;
}

.eva__barreau {
  font-size: 0.8rem;
  color: var(--muted);
  letter-spacing: 0.05em;
  margin-top: 0.25rem;
  max-width: 100%;
}

.eva__titre {
  font-size: clamp(2.2rem, 4vw, 3.5rem);
  color: var(--ink);
  margin-bottom: 2rem;
  line-height: 1.1;
}
.eva__titre em { font-style: italic; color: var(--gold); }

.eva__corps {
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
  margin-bottom: 2.5rem;
}
.eva__corps p {
  font-size: 1.05rem;
  font-weight: 300;
  color: var(--ink);
  line-height: 1.75;
  max-width: 52ch;
}

.eva__line {
  width: 3rem;
  height: 1px;
  background: var(--gold);
  margin-bottom: 1.75rem;
  transform-origin: left;
  transform: scaleX(0);
  transition: transform 0.6s var(--ease-out) 0.3s;
}
[data-reveal].visible .eva__line,
.eva__line.visible {
  transform: scaleX(1);
}

.eva__tags {
  display: flex;
  gap: 1.5rem;
  flex-wrap: wrap;
}
.eva__tags li {
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
  padding: 0.4rem 0.9rem;
  border: 1px solid var(--border);
}

@media (max-width: 768px) {
  .eva__inner { grid-template-columns: 1fr; gap: 2.5rem; }
  .eva__bg-initials { right: -3rem; top: auto; bottom: -2rem; transform: none; }
}
</style>
