---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Eva from '../components/Eva.astro';
import Domaines from '../components/Domaines.astro';
import Contact from '../components/Contact.astro';
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <Eva />
    <Domaines />
    <Contact />
  </main>
</Layout>

<script>
  // Active les transitions CSS reveal (fallback : tout visible sans JS)
  document.documentElement.classList.add('js-loaded');

  // ── IntersectionObserver — reveals ────────────────────────
  const revealObs = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        revealObs.unobserve(e.target);
      }
    }),
    { threshold: 0.12 }
  );
  document.querySelectorAll('[data-reveal], [data-reveal-stagger]').forEach(el =>
    revealObs.observe(el)
  );

  // ── Parallaxe (hero decor + EH bg initials) ───────────────
  const heroDecor   = document.querySelector<HTMLElement>('.hero__decor');
  const heroInit    = document.querySelector<HTMLElement>('.hero__initials span');
  const evaInit     = document.querySelector<HTMLElement>('.eva__bg-initials span');
  const evaSection  = document.querySelector<HTMLElement>('#eva');

  let ticking = false;
  window.addEventListener('scroll', () => {
    if (ticking) return;
    requestAnimationFrame(() => {
      const sy = window.scrollY;
      if (heroDecor) heroDecor.style.transform = `translateY(${sy * 0.35}px)`;
      if (heroInit)  heroInit.style.transform  = `translateY(${sy * 0.12}px)`;
      if (evaInit && evaSection) {
        const offset = sy - evaSection.offsetTop;
        evaInit.style.transform = `translateY(calc(-50% + ${offset * 0.1}px))`;
      }
      ticking = false;
    });
    ticking = true;
  }, { passive: true });

  // ── Magnetic CTA ──────────────────────────────────────────
  const cta  = document.querySelector<HTMLElement>('.hero-cta');
  const hero = document.querySelector<HTMLElement>('#hero');

  if (cta && hero && window.matchMedia('(pointer: fine)').matches) {
    hero.addEventListener('mousemove', e => {
      const r   = cta.getBoundingClientRect();
      const cx  = r.left + r.width  / 2;
      const cy  = r.top  + r.height / 2;
      const dx  = (e.clientX - cx) / r.width;
      const dy  = (e.clientY - cy) / r.height;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < 2) {
        const s = Math.max(0, 2 - dist) / 2;
        cta.style.transform = `translate(${dx * 9 * s}px, ${dy * 9 * s}px)`;
      } else {
        cta.style.transform = '';
      }
    });
    hero.addEventListener('mouseleave', () => { cta.style.transform = ''; });
  }

  // ── eva__line révélation indépendante ─────────────────────
  const lineObs = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.transform = 'scaleX(1)';
        lineObs.unobserve(e.target);
      }
    }),
    { threshold: 0.5 }
  );
  document.querySelectorAll('.eva__line').forEach(el => lineObs.observe(el));
</script>
