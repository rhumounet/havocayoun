---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Valeurs from '../components/Valeurs.astro';
import Domaines from '../components/Domaines.astro';
import APropos from '../components/APropos.astro';
import Processus from '../components/Processus.astro';
import Honoraires from '../components/Honoraires.astro';
import Contact from '../components/Contact.astro';
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <Valeurs />
    <Domaines />
    <APropos />
    <Processus />
    <Honoraires />
    <Contact />
  </main>
</Layout>

<script>
  // Fade-in on scroll
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>
